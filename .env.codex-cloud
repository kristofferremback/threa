# Codex cloud sandbox defaults. Matches docker-compose.yml port mappings.
DATABASE_URL=postgresql://threa:threa@localhost:5454/threa
TEST_DATABASE_URL=postgresql://threa:threa@localhost:5454/threa_test
NODE_ENV=development
PORT=3001
USE_STUB_AUTH=true
LOG_LEVEL=info
S3_BUCKET=threa-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9099
