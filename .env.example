# Database (matches docker-compose.yml)
DATABASE_URL=postgresql://threa:threa@localhost:5454/threa

# WorkOS Auth
WORKOS_API_KEY=sk_...
WORKOS_CLIENT_ID=client_...
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
WORKOS_COOKIE_PASSWORD=at-least-32-characters-long-secret

# Session cookie.
# SESSION_COOKIE_NAME distinguishes envs that share a browser and/or cookie
# domain. Use `wos_session` in production and `wos_session_staging` in staging
# so the two don't overwrite each other. Required — backend will refuse to
# start if unset (INV-11: no silent fallback defaults).
# COOKIE_DOMAIN widens the cookie scope across subdomains. Set to `.threa.io`
# in production and staging so sibling subdomains (e.g. pr-204-staging.threa.io)
# see the session after the WorkOS callback. Leave unset for local dev.
SESSION_COOKIE_NAME=wos_session
# COOKIE_DOMAIN=.threa.io

# Dev mode (bypasses WorkOS)
USE_STUB_AUTH=true

# Workspace creation invite requirement is enabled by default.
# Set to true only for local/dev environments that should bypass invite gating.
# WORKSPACE_CREATION_SKIP_INVITE=true

# Server
PORT=3001

# Logging
LOG_LEVEL=info

# Outbox retention lifecycle (optional)
# OUTBOX_RETENTION_INTERVAL_MS=300000
# OUTBOX_RETENTION_WINDOW_MS=604800000
# OUTBOX_RETENTION_BATCH_SIZE=1000
# OUTBOX_RETENTION_MAX_BATCHES_PER_RUN=10

# S3 Storage (uses MinIO locally via docker-compose)
S3_BUCKET=threa-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000

# Attachment upload safety
# MIME types are intentionally unrestricted for trusted colleague file sharing.
# ATTACHMENT_MALWARE_SCAN_ENABLED=true

# Video transcoding (optional; requires AWS MediaConvert + S3 access)
# MEDIACONVERT_ENABLED=false
# MEDIACONVERT_ROLE_ARN=arn:aws:iam::123456789012:role/threa-mediaconvert-dev
# MEDIACONVERT_ENDPOINT=https://abcd1234.mediaconvert.us-east-1.amazonaws.com

# GitHub App (optional; enables workspace-level GitHub integrations + rich link previews)
# GITHUB_APP_ID=1234567
# GITHUB_APP_SLUG=threa
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# WORKSPACE_INTEGRATIONS_SECRET=replace-with-a-long-random-secret
