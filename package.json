{
  "name": "threa",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:lan": "LAN_MODE=true bun scripts/dev.ts",
    "dev:test": "bun scripts/dev-test.ts",
    "dev:backend": "bun --hot apps/backend/src/index.ts",
    "dev:frontend": "bun run --cwd apps/frontend dev",
    "dev:backoffice": "bun run --cwd apps/backoffice dev",
    "db:start": "docker compose up -d postgres minio",
    "db:stop": "docker compose stop postgres minio",
    "db:reset": "docker compose down -v && docker compose up -d postgres minio",
    "db:backfill-cp": "bun scripts/backfill-control-plane.ts",
    "workos:sync": "bun scripts/sync-workos-permissions.ts",
    "workos:check": "bun scripts/sync-workos-permissions.ts --check",
    "monitoring:start": "docker compose -f docker-compose.monitoring.yml up -d",
    "monitoring:stop": "docker compose -f docker-compose.monitoring.yml stop",
    "monitoring:logs": "docker compose -f docker-compose.monitoring.yml logs -f",
    "setup:worktree": "bun scripts/setup-worktree.ts",
    "codex:setup": "bash scripts/codex-cloud-setup.sh",
    "codex:doctor": "bash scripts/codex-cloud-doctor.sh",
    "lint": "bun run --cwd apps/backend lint && bun run --cwd apps/control-plane lint && bun run --cwd apps/frontend lint && bun run --cwd apps/backoffice lint && bun run check:dockerfiles",
    "check:dockerfiles": "bun scripts/check-dockerfile-workspaces.ts",
    "typecheck": "bun run --cwd packages/types typecheck && bun run --cwd packages/prosemirror typecheck && bun run --cwd packages/backend-common typecheck && bun run --cwd apps/backend typecheck && bun run --cwd apps/control-plane typecheck && bun run --cwd apps/workspace-router typecheck && bun run --cwd apps/backoffice-router typecheck && bun run --cwd apps/frontend typecheck && bun run --cwd apps/backoffice typecheck",
    "eval": "bun run --cwd apps/backend eval --",
    "test": "bun run --cwd apps/backend test",
    "test:unit": "bun run --cwd apps/backend test:unit",
    "test:e2e": "bun run --cwd apps/backend test:e2e",
    "test:browser": "bun scripts/test-silent.ts browser",
    "test:browser:ui": "bunx playwright test --ui",
    "test:browser:headed": "bunx playwright test --headed",
    "test:browser:backend": "FAST_SHUTDOWN=true bun apps/backend/src/index.ts",
    "test:browser:control-plane": "FAST_SHUTDOWN=true bun apps/control-plane/src/index.ts",
    "test:browser:frontend": "bun run --cwd apps/frontend dev",
    "test:db:start": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:stop": "docker compose -f docker-compose.test.yml stop",
    "test:db:reset": "docker compose -f docker-compose.test.yml down -v && docker compose -f docker-compose.test.yml up -d --wait",
    "prepare": "husky",
    "docker:build:backend": "docker build -f Dockerfile.backend -t threa-backend .",
    "docker:build:control-plane": "docker build -f Dockerfile.control-plane -t threa-control-plane .",
    "docker:build": "bun run docker:build:backend && bun run docker:build:control-plane",
    "generate:api-docs": "bun apps/backend/scripts/generate-api-docs.ts",
    "generate:api-docs:check": "bun apps/backend/scripts/generate-api-docs.ts --check",
    "infra:validate": "cd infra/aws && terraform validate",
    "test:codex:cloud": "bash scripts/test-codex-cloud.sh"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@playwright/test": "^1.57.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "shadcn": "^3.6.3"
  },
  "lint-staged": {
    "!(.agents|.claude)/**/*.{js,jsx,ts,tsx,json,css,md,html}": "prettier --write"
  },
  "dependencies": {
    "limax": "^4.2.2"
  }
}
